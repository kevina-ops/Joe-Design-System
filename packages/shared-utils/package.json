{
    "name": "@joe-coffee/shared-utils",
    "version": "0.1.0",
    "description": "Shared utilities for Joe Coffee design system packages",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "tsc --noEmit"
    },
    "peerDependencies": {
        "clsx": "^2.0.0",
        "tailwind-merge": "^2.0.0"
    },
    "devDependencies": {
        "clsx": "^2.1.1",
        "tailwind-merge": "^2.4.0",
        "tsup": "^8.0.0",
        "typescript": "^5.5.0"
    }
}