{
    "name": "@joe-coffee/consumer-ui",
    "version": "0.1.0",
    "description": "Joe Coffee Consumer App UI package",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        },
        "./globals.css": "./src/globals.css"
    },
    "files": [
        "dist",
        "src/globals.css"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "tsc --noEmit",
        "storybook": "storybook dev -p 6006 -c .storybook",
        "build-storybook": "storybook build -c .storybook",
        "tokens:build": "node ../../scripts/build-tokens.mjs --platform consumer"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "dependencies": {
        "@joe-coffee/shared-utils": "workspace:*"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.22.0",
        "@babel/preset-react": "^7.22.0",
        "@babel/preset-typescript": "^7.22.0",
        "@storybook/addon-a11y": "^10.2.3",
        "@storybook/react-webpack5": "^10.2.3",
        "babel-loader": "^9.1.3",
        "postcss": "^8.5.6",
        "postcss-loader": "^8.2.0",
        "storybook": "^10.2.3",
        "storybook-design-token": "^5.0.0",
        "tailwindcss": "^3.4.0",
        "tailwindcss-animate": "^1.0.7",
        "tsup": "^8.0.0",
        "typescript": "^5.5.0"
    }
}