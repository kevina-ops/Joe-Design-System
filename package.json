{
  "name": "joe-design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Joe Coffee's Design System - Token-driven React component library",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "tokens:build": "node scripts/build-tokens.mjs",
    "tokens:build:consumer": "node scripts/build-tokens.mjs --platform consumer",
    "tokens:build:merchant": "node scripts/build-tokens.mjs --platform merchant",
    "tokens:build:pos": "node scripts/build-tokens.mjs --platform pos",
    "tokens:watch": "node scripts/build-tokens.mjs --watch",
    "tokens:import-obra": "node scripts/import-obra-tokens.mjs",
    "tokens:import-figma": "node scripts/import-figma-variables.mjs",
    "tokens:import-figma-folder": "node scripts/import-figma-folder.mjs",
    "components:generate": "node scripts/generate-components.mjs --all",
    "components:generate:single": "node scripts/generate-components.mjs --component",
    "preinstall": "node -e \"if(process.version.split('.')[0].slice(1) < 20) throw new Error('Node.js 20+ required. Run: nvm use')\"",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "chromatic": "turbo run chromatic",
    "chromatic:consumer": "pnpm run tokens:build:consumer && pnpm --filter @joe-coffee/consumer-ui run build-storybook && pnpm exec chromatic --project-token $CHROMATIC_PROJECT_TOKEN_CONSUMER --storybook-build-dir packages/consumer-ui/storybook-static",
    "chromatic:merchant": "pnpm run tokens:build:merchant && pnpm --filter @joe-coffee/merchant-ui run build-storybook && pnpm exec chromatic --project-token $CHROMATIC_PROJECT_TOKEN_MERCHANT --storybook-build-dir packages/merchant-ui/storybook-static",
    "chromatic:pos": "pnpm run tokens:build:pos && pnpm --filter @joe-coffee/pos-ui run build-storybook && pnpm exec chromatic --project-token $CHROMATIC_PROJECT_TOKEN_POS --storybook-build-dir packages/pos-ui/storybook-static",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@phosphor-icons/react": "^2.1.5",
    "@storybook/addon-a11y": "^10.2.3",
    "@storybook/react-webpack5": "^10.2.3",
    "@types/node": "25.1.0",
    "@types/react": "19.2.10",
    "babel-loader": "^9.1.3",
    "chromatic": "^15.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "storybook": "^10.2.3",
    "storybook-design-token": "^5.0.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "@changesets/cli": "^2.27.0",
    "autoprefixer": "^10.4.20"
  }
}