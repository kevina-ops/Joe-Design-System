{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "tokens:build": {
            "inputs": [
                "tokens/joe-tokens.json",
                "tokens/semantic/**"
            ],
            "outputs": [
                "tokens/output/**"
            ]
        },
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "storybook": {
            "cache": false,
            "persistent": true
        },
        "build-storybook": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "storybook-static/**"
            ]
        },
        "lint": {},
        "chromatic": {
            "dependsOn": [
                "build-storybook"
            ]
        }
    }
}